<Window x:Class="steel_structures_nodes.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:steel_structures_nodes.Wpf.ViewModels"
        Title="steel_structures_nodes RS1" Width="1400" MinWidth="600" MinHeight="400"
        WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="False"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        WindowState="{Binding CurrentWindowState, Mode=TwoWay}" Height="3068">

    <Window.Resources>
        <!-- Переопределение стиля SelectableValue: добавлена кнопка копирования в буфер обмена -->
        <Style x:Key="SelectableValue" TargetType="TextBox">
            <Setter Property="IsReadOnly"        Value="True"/>
            <Setter Property="FontSize"          Value="18"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <!-- Стандартный хост содержимого TextBox -->
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Grid.Column="0"
                                          VerticalAlignment="Center"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Hidden"/>
                            <!-- Кнопка копирования — всегда видима, ярче при наведении -->
                            <Button x:Name="CopyBtn"
                                    Grid.Column="1"
                                    Width="26" Height="26"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip="Копировать"
                                    Opacity="0.45"
                                    Tag="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Text}"
                                    Click="CopyValue_Click">
                                <TextBlock Text="&#xE8C8;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </Button>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Полная яркость при наведении курсора на TextBox -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CopyBtn" Property="Opacity" Value="1.0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource MutedBrush}" BorderThickness="1">
        <Grid Background="#FFF5F7FA">
            <DockPanel>
                <!-- Строка заголовка — статичная на рамке окна -->
                <DockPanel DockPanel.Dock="Top" Background="{StaticResource TitleBarBackground}" Height="34"
                   MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,2,0">
                        <Button ToolTip="Свернуть" Style="{StaticResource CaptionButton}"
                        Command="{Binding MinimizeCommand}">
                            <TextBlock Text="&#xE921;" Style="{StaticResource CaptionIcon}"/>
                        </Button>
                        <Button ToolTip="Развернуть / Восстановить" Style="{StaticResource CaptionButton}"
                        Command="{Binding MaximizeRestoreCommand}">
                            <TextBlock Text="{Binding MaximizeRestoreIcon}" Style="{StaticResource CaptionIcon}"/>
                        </Button>
                        <Button ToolTip="Закрыть" Style="{StaticResource CaptionButton}"
                        Command="{Binding CloseCommand}">
                            <TextBlock Text="&#xE8BB;" Style="{StaticResource CaptionIcon}"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Style="{StaticResource TitleBarText}"
                       Text="Анализ узлового соединения металлических конструкций"
                       Margin="8,0,0,0"/>
                </DockPanel>

                <ScrollViewer x:Name="MainScrollViewer" Margin="12,8,12,12" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Viewbox Stretch="Uniform" StretchDirection="Both">
                        <StackPanel Width="1376">


                            <!-- Выбор узлового соединения -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="420" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="800" />
                                </Grid.ColumnDefinitions>

                                <!-- Left: aligned form layout -->
                                <Grid Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя группы узловых соединений" Style="{StaticResource FormLabel}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" MinHeight="30" Margin="0,0,0,8"
                                              ItemsSource="{Binding ConnectionCodes}"
                                              SelectedItem="{Binding ConnectionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Профиль колонны" Style="{StaticResource FormLabel}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ProfileColumn" MinHeight="30" Margin="0,0,0,8"
                                              ItemsSource="{Binding ElementSectionsColumn}"
                                              SelectedItem="{Binding ElementSectionColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Профиль балки" Style="{StaticResource FormLabel}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ProfileBeam" MinHeight="30" Margin="0,0,0,8"
                                              ItemsSource="{Binding ElementSectionsBeam}"
                                              SelectedItem="{Binding ElementSectionBeam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Код соединения (авто)" Style="{StaticResource FormLabel}" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1" MinHeight="30" Margin="0,0,0,8"
                                              ItemsSource="{Binding ConnectionCodeItems}"
                                              SelectedItem="{Binding StandardConnectionCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="False"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Коэффициент γf" Style="{StaticResource FormLabel}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Row="4" Grid.Column="1" MinHeight="30"
                                              ItemsSource="{Binding GammaFOptions}"
                                              SelectedItem="{Binding GammaF, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <!-- Preview (right) -->
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Preview" Style="{StaticResource PreviewTitle}" Margin="0,-4,0,8" />
                                    <Border Grid.Row="1"
                            Height="500" Width="600"
                            HorizontalAlignment="Left"
                            BorderBrush="{StaticResource MutedBrush}" BorderThickness="1"
                            Background="White" Padding="4"
                            ClipToBounds="True" Margin="0,0,0,6">
                                        <Grid ClipToBounds="True">
                                            <Image Source="{Binding SelectedNodeImage}" Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality" Margin="0,-4,0,4" />
                                            <TextBlock Text="no image" Foreground="{StaticResource MutedBrush}" FontStyle="Italic"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedNodeImage}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Стрелка влево -->
                                            <Button Command="{Binding PrevImageCommand}"
                                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                                Width="32" Height="32" Opacity="0.7"
                                                Background="#CCFFFFFF" BorderThickness="0"
                                                Visibility="{Binding HasMultipleImages, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>

                                            <!-- Стрелка вправо -->
                                            <Button Command="{Binding NextImageCommand}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Width="32" Height="32" Opacity="0.7"
                                                Background="#CCFFFFFF" BorderThickness="0"
                                                Visibility="{Binding HasMultipleImages, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>

                                            <!-- Индикатор номера -->
                                            <TextBlock Text="{Binding ImageIndexText}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#555" Background="#CCFFFFFF" Padding="6,2"
                                                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"
                                                   Visibility="{Binding HasMultipleImages, Converter={StaticResource BoolToVisibility}}"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Row="2" Margin="0,4,0,0" Foreground="{StaticResource SubtitleBrush}" TextWrapping="Wrap">
                        <Run Text="Code: " />
                        <Run Text="{Binding NodeTopology}" />
                        <Run Text="  " />
                        <Run Text="{Binding SelectedNodeDescription, Mode=OneWay}" />
                                    </TextBlock>
                                </Grid>
                            </Grid>

                            <!-- Примечания из поля Explanations базы данных — на всю ширину, авторазмер -->
                            <Border Margin="0,0,0,8" Padding="12,10"
                                    Background="#F5F7FA"
                                    BorderBrush="{StaticResource MutedBrush}" BorderThickness="1"
                                    CornerRadius="4"
                                    Visibility="{Binding HasNodeExplanation, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="Примечания"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding NodeExplanation}"
                                               TextWrapping="Wrap" FontSize="12"
                                               Foreground="{StaticResource SubtitleBrush}"
                                               LineHeight="18"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,0,8"
        Padding="12,10"
        Background="#F5F7FA"
        BorderBrush="{StaticResource MutedBrush}"
        BorderThickness="1"
        CornerRadius="4"
        HorizontalAlignment="Stretch">
                                <TextBlock TextWrapping="Wrap"
               FontSize="12"
               Foreground="{StaticResource SubtitleBrush}">
        <Run Text="Тип узла(Rigid Joint - жесткое соединение, Hinged Joint - шарнирное соединение): "
             FontWeight="SemiBold"
             Foreground="{StaticResource AccentBrush}" />
        <Run Text="{Binding StandardNode.TypeNode, Mode=OneWay}" />
        <LineBreak />
        <Run Text="Тип опорного столика: "
             FontWeight="SemiBold"
             Foreground="{StaticResource AccentBrush}" />
        <Run Text="{Binding StandardNode.TableBrand, Mode=OneWay}" />
                                </TextBlock>
                            </Border>
                            <GroupBox Header="Максимальная несущая способность узлового соединения" Style="{StaticResource SectionGroup}">
                                <StackPanel>
                                    <Button Content="📋 Копировать данные узла"
                            Command="{Binding CopyNodeDataToClipboardCommand}"
                            Style="{StaticResource ActionButton}"/>
                                    <!-- Несущая способность | Жёсткость | Коэффициенты взаимодействия -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Несущая способность (слева) -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Несущая способность" Style="{StaticResource SectionTitle}"/>

                                            <!-- Продольные силы -->
                                            <TextBlock Text="Продольные силы" Style="{StaticResource SubtitleTextSpaced}"/>
                                            <Grid Margin="4,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                                                    <ColumnDefinition Width="220"/>
                                                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                                                    <ColumnDefinition Width="220"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Растягивающая осевая сила (+)" Style="{StaticResource SubtitleText}"/>
                                                <TextBlock Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Text="Сжимающая осевая сила (-)" Style="{StaticResource SubtitleText}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Nt, кН:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding StandardNode.Nt, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Nc, кН:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding StandardNode.Nc, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="Продольная сила +/-" Style="{StaticResource SubtitleTextSpaced}"/>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="N, кН:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding StandardNode.N, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                            </Grid>

                                            <!-- Поперечные силы -->
                                            <TextBlock Text="Поперечные силы" Style="{StaticResource SubtitleTextSpaced}"/>
                                            <Grid Margin="4,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                                                    <ColumnDefinition Width="220"/>
                                                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                                                    <ColumnDefinition Width="220"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Поперечная сила в плоскости Uy" Style="{StaticResource SubtitleText}"/>
                                                <TextBlock Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Text="Поперечная сила в плоскости Uz" Style="{StaticResource SubtitleText}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Qy, кН:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding StandardNode.Qy, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Qz, кН:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding StandardNode.Qz, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                            </Grid>

                                            <!-- Изгибающие моменты -->
                                            <TextBlock Text="Изгибающие моменты" Style="{StaticResource SubtitleTextSpaced}"/>
                                            <Grid Margin="4,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                                                    <ColumnDefinition Width="220"/>
                                                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                                                    <ColumnDefinition Width="220"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Крутящий момент" Style="{StaticResource SubtitleText}"/>
                                                <TextBlock Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Text="Изгибающий момент в плоскости Uy" Style="{StaticResource SubtitleText}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Mx, кН·м:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding StandardNode.Mx, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="2" Text="My, кН·м:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding StandardNode.My, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="Изгибающий момент в плоскости Uz" Style="{StaticResource SubtitleTextSpaced}"/>
                                                <TextBlock Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Text="Бимомент (депланация)" Style="{StaticResource SubtitleTextSpaced}"/>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Mz, кН·м:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding StandardNode.Mz, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Mw, кН·м²:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding StandardNode.Mw, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="Отрицательный изгибающий момент" Style="{StaticResource SubtitleTextSpaced}"/>
                                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Mneg, кН·м:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding StandardNode.Mneg, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Жёсткость (центр) -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Жёсткость" Style="{StaticResource SectionTitle}"/>
                                            <Grid Margin="4,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Жёсткость узла в плоскости Uy" Style="{StaticResource SubtitleText}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Sj, кН·м/рад:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding StandardNode.Sj, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="Жёсткость узла в плоскости Uz" Style="{StaticResource SubtitleTextSpaced}"/>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Sjo, кН·м/рад:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding StandardNode.Sjo, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="Вариант исполнения узла" Style="{StaticResource SubtitleTextSpaced}"/>
                                                <TextBlock Grid.Row="5" Grid.Column="0" Text="var:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding StandardNode.Variable, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Коэффициенты взаимодействия (справа) -->
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Коэффициенты взаимодействия" Style="{StaticResource SectionTitle}"/>
                                            <Grid Margin="4,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Осевая сила N" Style="{StaticResource SubtitleText}" Margin="0,0,-116,28" Grid.RowSpan="2"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="α:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding StandardNode.Alpha, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Text="Изгибающий момент My" Style="{StaticResource SubtitleTextSpaced}" Margin="0,4,-116,0"/>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="β:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding StandardNode.Beta, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="Поперечная сила Q" Style="{StaticResource SubtitleTextSpaced}" Margin="0,4,-116,28" Grid.RowSpan="2"/>
                                                <TextBlock Grid.Row="5" Grid.Column="0" Text="γ:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding StandardNode.Gamma, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Text="Крутящий момент Mx" Style="{StaticResource SubtitleTextSpaced}" Margin="0,4,-116,0"/>
                                                <TextBlock Grid.Row="7" Grid.Column="0" Text="δ:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding StandardNode.Delta, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Text="Бимомент Mw" Style="{StaticResource SubtitleTextSpaced}" Margin="0,4,-116,28" Grid.RowSpan="2"/>
                                                <TextBlock Grid.Row="9" Grid.Column="0" Text="ε:" Style="{StaticResource FieldLabel}" Margin="0,9,4,0" VerticalAlignment="Top"/>
                                                <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding StandardNode.Epsilon, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" Text="Отрицательный момент Mneg" Style="{StaticResource SubtitleTextSpaced}" Margin="0,4,-116,28" Grid.RowSpan="2"/>
                                                <TextBlock Grid.Row="11" Grid.Column="0" Text="λ:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding StandardNode.Lambda, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                    <Separator/>

                                    <!-- Геометрия узла -->
                                    <TextBlock Text="Геометрия узла" Style="{StaticResource SectionTitle}"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Колонна и Балка (слева) -->
                                        <Grid Grid.Column="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Колонна -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Колонна" Style="{StaticResource SubtitleText}"/>
                                                <Grid Margin="4,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
