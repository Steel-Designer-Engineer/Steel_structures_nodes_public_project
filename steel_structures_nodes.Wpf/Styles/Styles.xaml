<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Конвертеры -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

    <!-- Основные цвета -->
    <SolidColorBrush x:Key="AccentBrush"         Color="#2B579A"></SolidColorBrush>
    <SolidColorBrush x:Key="SubtitleBrush"        Color="#666666"></SolidColorBrush>
    <SolidColorBrush x:Key="MutedBrush"           Color="#888888"></SolidColorBrush>
    <SolidColorBrush x:Key="TitleBarBackground"   Color="#F0F0F0"></SolidColorBrush>

    <!-- Диаграммы и статусы -->
    <SolidColorBrush x:Key="ChartTableBrush"      Color="#4A90D9"></SolidColorBrush>
    <SolidColorBrush x:Key="ChartCalcBrush"       Color="#E67E22"></SolidColorBrush>
    <SolidColorBrush x:Key="ChartUserBrush"       Color="#107C10"></SolidColorBrush>
    <SolidColorBrush x:Key="OverLimitBrush"       Color="#E74C3C"></SolidColorBrush>
    <SolidColorBrush x:Key="OkBrush"              Color="#27AE60"></SolidColorBrush>

    <!-- Фон строк -->
    <SolidColorBrush x:Key="AltRowBackground"         Color="#F8F8F8"></SolidColorBrush>
    <SolidColorBrush x:Key="OverLimitRowBackground"   Color="#FFF0F0"></SolidColorBrush>

    <!-- Заголовки таблицы соответствия -->
    <SolidColorBrush x:Key="AlbumHeaderBrush"  Color="#E8F0FE"></SolidColorBrush>
    <SolidColorBrush x:Key="LiraHeaderBrush"   Color="#FFF3E0"></SolidColorBrush>
    <SolidColorBrush x:Key="IdeaHeaderBrush"   Color="#E8F5E9"></SolidColorBrush>

    <!-- Стили текста -->

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontWeight"  Value="Bold"></Setter>
        <Setter Property="FontSize"    Value="20"></Setter>
        <Setter Property="Foreground"  Value="{StaticResource AccentBrush}"></Setter>
        <Setter Property="Margin"      Value="0,0,0,4"></Setter>
    </Style>

    <Style x:Key="SectionTitleSpaced" TargetType="TextBlock" BasedOn="{StaticResource SectionTitle}">
        <Setter Property="Margin" Value="0,4,0,4"></Setter>
    </Style>

    <Style x:Key="SubtitleText" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource SubtitleBrush}"></Setter>
        <Setter Property="FontSize"     Value="17"></Setter>
        <Setter Property="TextWrapping"  Value="Wrap"></Setter>
    </Style>

    <Style x:Key="SubtitleTextSpaced" TargetType="TextBlock" BasedOn="{StaticResource SubtitleText}">
        <Setter Property="Margin" Value="0,4,0,0"></Setter>
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontWeight"          Value="SemiBold"></Setter>
        <Setter Property="FontSize"            Value="18"></Setter>
        <Setter Property="Margin"              Value="0,2,4,2"></Setter>
        <Setter Property="VerticalAlignment"   Value="Center"></Setter>
    </Style>

    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="FontWeight"          Value="SemiBold"></Setter>
        <Setter Property="FontSize"            Value="18"></Setter>
        <Setter Property="VerticalAlignment"   Value="Center"></Setter>
        <Setter Property="Margin"              Value="0,0,8,0"></Setter>
    </Style>

    <Style x:Key="TitleBarText" TargetType="TextBlock">
        <Setter Property="FontSize"            Value="14"></Setter>
        <Setter Property="FontWeight"          Value="SemiBold"></Setter>
        <Setter Property="VerticalAlignment"   Value="Center"></Setter>
    </Style>

    <Style x:Key="PreviewTitle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold"></Setter>
        <Setter Property="Margin"     Value="0,0,0,4"></Setter>
    </Style>

    <Style x:Key="CaptionIcon" TargetType="TextBlock">
        <Setter Property="FontFamily"          Value="Segoe MDL2 Assets"></Setter>
        <Setter Property="FontSize"            Value="10"></Setter>
        <Setter Property="HorizontalAlignment" Value="Center"></Setter>
        <Setter Property="VerticalAlignment"   Value="Center"></Setter>
    </Style>

    <Style x:Key="ChartLabel" TargetType="TextBlock">
        <Setter Property="FontWeight"          Value="SemiBold"></Setter>
        <Setter Property="FontSize"            Value="18"></Setter>
        <Setter Property="VerticalAlignment"   Value="Center"></Setter>
        <Setter Property="TextWrapping"        Value="Wrap"></Setter>
    </Style>

    <Style x:Key="ChartTableValue" TargetType="TextBlock">
        <Setter Property="Foreground"          Value="{StaticResource ChartTableBrush}"></Setter>
        <Setter Property="FontSize"            Value="18"></Setter>
        <Setter Property="FontWeight"          Value="SemiBold"></Setter>
        <Setter Property="VerticalAlignment"   Value="Center"></Setter>
        <Setter Property="HorizontalAlignment" Value="Right"></Setter>
        <Setter Property="Margin"              Value="4,0"></Setter>
    </Style>

    <Style x:Key="LegendLabel" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="18"></Setter>
        <Setter Property="VerticalAlignment" Value="Center"></Setter>
    </Style>

    <Style x:Key="LegendHint" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="17"></Setter>
        <Setter Property="Foreground"        Value="{StaticResource MutedBrush}"></Setter>
        <Setter Property="VerticalAlignment" Value="Center"></Setter>
    </Style>

    <!-- Поле только для чтения (копируемое) -->
    <Style x:Key="SelectableValue" TargetType="TextBox">
        <Setter Property="IsReadOnly"         Value="True"></Setter>
        <Setter Property="FontSize"           Value="18"></Setter>
        <Setter Property="BorderThickness"    Value="0"></Setter>
        <Setter Property="Background"         Value="Transparent"></Setter>
        <Setter Property="VerticalAlignment"  Value="Center"></Setter>
        <Setter Property="Margin"             Value="0,1"></Setter>
    </Style>

    <!-- Стили кнопок -->

    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Width"            Value="46"></Setter>
        <Setter Property="Height"           Value="34"></Setter>
        <Setter Property="BorderThickness"  Value="0"></Setter>
        <Setter Property="Background"       Value="Transparent"></Setter>
    </Style>

    <Style x:Key="ActionButton" TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
        <Setter Property="Margin"              Value="0,0,0,8"></Setter>
        <Setter Property="Padding"             Value="12,6"></Setter>
    </Style>

    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Padding"             Value="8,6"/>
        <Setter Property="Margin"              Value="0"/>
    </Style>

    <!-- Контейнеры -->

    <Style x:Key="SectionGroup" TargetType="GroupBox">
        <Setter Property="Margin" Value="0,0,0,8"></Setter>
    </Style>

</ResourceDictionary>
