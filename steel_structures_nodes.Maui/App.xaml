<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:steel_structures_nodes.Maui.Converters"
             x:Class="steel_structures_nodes.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <conv:IsNullConverter x:Key="IsNullConverter" />
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <Color x:Key="Primary">#2B579A</Color>
            <Color x:Key="PrimaryLight">#5B8CC8</Color>
            <Color x:Key="Accent">#217346</Color>
            <Color x:Key="Surface">#F5F7FA</Color>
            <Color x:Key="OnSurface">#1A1A1A</Color>
            <Color x:Key="Muted">#888888</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>

            <!-- Implicit: цвет текста по умолчанию для всех Label без явного стиля -->
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="#1A1A1A"/>
            </Style>

            <Style TargetType="Label" x:Key="SectionHeader">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                <Setter Property="Margin" Value="0,12,0,6"/>
            </Style>

            <Style TargetType="Label" x:Key="FieldLabel">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="TextColor" Value="{StaticResource Muted}"/>
                <Setter Property="VerticalTextAlignment" Value="Center"/>
            </Style>

            <Style TargetType="Label" x:Key="FieldValue">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="#1A1A1A"/>
                <Setter Property="VerticalTextAlignment" Value="Center"/>
            </Style>

            <!-- Picker: явный цвет текста, чтобы выбранное значение было видно на белом фоне -->
            <Style TargetType="Picker">
                <Setter Property="TextColor" Value="#1A1A1A"/>
                <Setter Property="TitleColor" Value="{StaticResource Muted}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- Entry: аналогично -->
            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="#1A1A1A"/>
                <Setter Property="PlaceholderColor" Value="{StaticResource Muted}"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
