                                                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding StandardNode.WeldKf8, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="8" Grid.Column="0" Text="kf9:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding StandardNode.WeldKf9, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>

                                                <TextBlock Grid.Row="9" Grid.Column="0" Text="kf10:" Style="{StaticResource FieldLabel}"/>
                                                <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding StandardNode.WeldKf10, Mode=OneWay}" Style="{StaticResource SelectableValue}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>
                            </GroupBox>


                            <!-- Данные максимальной несущей способности узлового соединения -->

                            <GroupBox Header="Пользовательские усилия" Style="{StaticResource SectionGroup}">
                                <StackPanel>
                                    <TextBlock Text="Эти усилия добавляются на диаграмму несущей способности как отдельная серия."
                                               Style="{StaticResource SubtitleText}"
                                               Margin="0,0,0,8"/>
                                    <Grid Margin="4,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Nt, кН:" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding UserNt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Nc, кН:" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding UserNc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="N, кН:" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding UserN, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Qy, кН:" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding UserQy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Qz, кН:" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding UserQz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Mx, кН·м:" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding UserMx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="My, кН·м:" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding UserMy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="4" Text="Mz / Mw, кН·м / кН·м²:" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Grid.Row="2" Grid.Column="5" Orientation="Horizontal">
                                            <TextBox Width="46" Margin="0,0,6,0" Text="{Binding UserMz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBox Width="46" Text="{Binding UserMw, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </GroupBox>

                            <!-- Сравнительная диаграмма: табличные vs расчётные -->
                            <GroupBox Header="График несущей способности" Style="{StaticResource SectionGroup}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Легенда -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="16" Height="16" Background="{StaticResource ChartTableBrush}" CornerRadius="2" Margin="0,0,4,0"/>
                                        <TextBlock Text="Табличные" Style="{StaticResource LegendLabel}" Margin="0,0,20,0"/>
                                        <Border Width="16" Height="16" Background="{StaticResource ChartCalcBrush}" CornerRadius="2" Margin="0,0,4,0"/>
                                        <TextBlock Text="Расчётные" Style="{StaticResource LegendLabel}" Margin="0,0,20,0"/>
                                        <Border Width="16" Height="16" Background="{StaticResource ChartUserBrush}" CornerRadius="2" Margin="0,0,4,0"/>
                                        <TextBlock Text="Пользовательские" Style="{StaticResource LegendLabel}" Margin="0,0,20,0"/>
                                        <TextBlock Text="Использование = max(расчётное, пользовательское) / табличное × 100%" Style="{StaticResource LegendHint}"/>
                                    </StackPanel>

                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ComparisonItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="4,4" Margin="0,1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource AltRowBackground}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOverLimit}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource OverLimitRowBackground}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="180"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="70"/>
                                                            <ColumnDefinition Width="65"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- Метка параметра -->
                                                        <TextBlock Grid.Column="0" Grid.RowSpan="3"
                                               Text="{Binding Label}" Style="{StaticResource ChartLabel}"/>

                                                        <!-- Полоса табличного значения -->
                                                        <Border Grid.Row="0" Grid.Column="1" Height="14"
                                            Background="{StaticResource ChartTableBrush}" HorizontalAlignment="Left"
                                            Width="{Binding TableBarWidth}" CornerRadius="2" Margin="0,2"/>

                                                        <!-- Полоса расчётного значения -->
                                                        <Border Grid.Row="1" Grid.Column="1" Height="14"
                                            HorizontalAlignment="Left"
                                            Width="{Binding CalcBarWidth}" CornerRadius="2" Margin="0,2">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{StaticResource ChartCalcBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOverLimit}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource OverLimitBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>

                                                        <!-- Полоса пользовательского значения -->
                                                        <Border Grid.Row="2" Grid.Column="1" Height="14"
                                            Background="{StaticResource ChartUserBrush}" HorizontalAlignment="Left"
                                            Width="{Binding UserBarWidth}" CornerRadius="2" Margin="0,2"/>

                                                        <!-- Числовое табличное значение -->
                                                        <TextBlock Grid.Row="0" Grid.Column="2"
                                               Text="{Binding TableText}" Style="{StaticResource ChartTableValue}"/>

                                                        <!-- Числовое расчётное значение -->
                                                        <TextBlock Grid.Row="1" Grid.Column="2"
                                               FontSize="18" FontWeight="SemiBold"
                                               VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource ChartCalcBrush}"/>
                                                                    <Setter Property="Text" Value="{Binding CalcText}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOverLimit}" Value="True">
                                                                            <Setter Property="Foreground" Value="{StaticResource OverLimitBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>

                                                        <!-- Числовое пользовательское значение -->
                                                        <TextBlock Grid.Row="2" Grid.Column="2"
                                               Foreground="{StaticResource ChartUserBrush}"
                                               FontSize="18" FontWeight="SemiBold"
                                               VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0"
                                               Text="{Binding UserText}"/>

                                                        <!-- Процент использования -->
                                                        <TextBlock Grid.Column="4" Grid.RowSpan="3"
                                               Text="{Binding RatioText}" FontSize="20" FontWeight="Bold"
                                               VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOverLimit}" Value="True">
                                                                            <Setter Property="Foreground" Value="{StaticResource OverLimitBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </GroupBox>

                            <!-- Сводка результатов расчёта -->
                            <GroupBox Header="Сводка результатов расчёта" Style="{StaticResource SectionGroup}">
                                <StackPanel>
                                    <Button Content="📋 Копировать сводку"
                                            Command="{Binding CopyResultsToClipboardCommand}"
                                            Style="{StaticResource ActionButton}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Версия расчёта:" Style="{StaticResource FormLabel}"/>
                                        <ComboBox MinWidth="200"
                                  ItemsSource="{Binding CalculationVersions}"
                                  SelectedItem="{Binding SelectedCalculationVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              MaxHeight="200">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Параметр" Binding="{Binding Key}" Width="*"/>
                                            <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </GroupBox>

                            <!-- Полная таблица анализа (MAX-строки) -->
                            <GroupBox Header="Таблица результатов анализа" Style="{StaticResource SectionGroup}">
                                <DockPanel>
                                    <Button DockPanel.Dock="Top" Content="📋 Копировать таблицу анализа"
                            Command="{Binding CopyAnalysisToClipboardCommand}"
                            Style="{StaticResource ActionButton}"/>
                                    <DataGrid ItemsSource="{Binding AnalysisRows}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              MaxHeight="350">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Критерий" Binding="{Binding RowType}" Width="110"/>
                                            <DataGridTextColumn Header="Комбинации нагрузок" Binding="{Binding LoadCombination}" Width="170"/>
                                            <DataGridTextColumn Header="Элемент" Binding="{Binding ElementText}" Width="80"/>

                                            <DataGridTextColumn Header="N (кН)" Binding="{Binding N, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="Nt (кН)" Binding="{Binding Nt, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="Nc (кН)" Binding="{Binding Nc, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="Qy (кН)" Binding="{Binding Qy, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="Qz (кН)" Binding="{Binding Qz, StringFormat={}{0:0.#####}}" Width="90"/>

                                            <DataGridTextColumn Header="Mx (кН·м)" Binding="{Binding Mx, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="My (кН·м)" Binding="{Binding My, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="Mz (кН·м)" Binding="{Binding Mz, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="Mw (кН*м²)" Binding="{Binding Mw, StringFormat={}{0:0.#####}}" Width="95"/>

                                            <DataGridTextColumn Header="u" Binding="{Binding U, StringFormat={}{0:0.#####}}" Width="70"/>
                                            <DataGridTextColumn Header="ψ" Binding="{Binding Psi, StringFormat={}{0:0.#####}}" Width="70"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </GroupBox>

                            <!-- Нагрузки для IDEA StatiCA -->
                            <GroupBox Header="Соответствие наименований (Альбом ↔ Лира ↔ IDEA StatiCA)" Style="{StaticResource SectionGroup}">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <Grid>
                                        <Grid.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="{StaticResource MutedBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                            </Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </Grid.Resources>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Заголовки: Альбом -->
                                        <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource AlbumHeaderBrush}">
                                            <TextBlock Text="Альбом" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1">
                                            <TextBlock Text="N, kN"/>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="2">
                                            <TextBlock Text="Qo, kN"/>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="3">
                                            <TextBlock Text="Q, kN"/>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="4">
                                            <TextBlock Text="T, kN·м"/>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="5">
                                            <TextBlock Text="M, kN·м"/>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="6">
                                            <TextBlock Text="Mo, kN·м"/>
                                        </Border>

                                        <!-- Заголовки: Лира/SCAD -->
                                        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource LiraHeaderBrush}">
                                            <TextBlock Text="Лира / SCAD" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="1">
                                            <TextBlock Text="N, kN"/>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="2">
                                            <TextBlock Text="QY, kN"/>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="3">
                                            <TextBlock Text="QZ, kN"/>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="4">
                                            <TextBlock Text="MK, kN·м"/>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="5">
                                            <TextBlock Text="MY, kN·м"/>
                                        </Border>
                                        <Border Grid.Row="1" Grid.Column="6">
                                            <TextBlock Text="MZ, kN·м"/>
                                        </Border>

                                        <!-- Заголовки: IDEA StatiCA -->
                                        <Border Grid.Row="2" Grid.Column="0" Background="{StaticResource IdeaHeaderBrush}">
                                            <TextBlock Text="IDEA StatiCA" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="1">
                                            <TextBlock Text="N, kN" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="2">
                                            <TextBlock Text="Vy, kN" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="3">
                                            <TextBlock Text="Vz, kN" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="4">
                                            <TextBlock Text="Mx, kN·м" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="5">
                                            <TextBlock Text="My, kN·м" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Grid.Row="2" Grid.Column="6">
                                            <TextBlock Text="Mz, kN·м" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </ScrollViewer>
                            </GroupBox>

                            <GroupBox Header="Нагрузки для IDEA StatiCA (из результатов анализа)" Style="{StaticResource SectionGroup}">
                                <DockPanel>
                                    <Button DockPanel.Dock="Top" Content="📋 Копировать таблицу в буфер обмена"
                            Command="{Binding CopyIdeaToClipboardCommand}"
                            Style="{StaticResource ActionButton}"/>
                                    <DataGrid ItemsSource="{Binding IdeaRows}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              MaxHeight="400">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Критерий" Binding="{Binding RowType}" Width="110"/>
                                            <DataGridTextColumn Header="N, kN" Binding="{Binding N, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="Vy, kN" Binding="{Binding Vy, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="Vz, kN" Binding="{Binding Vz, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="Mx, kN·м" Binding="{Binding Mx, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="My, kN·м" Binding="{Binding My, StringFormat={}{0:0.#####}}" Width="90"/>
                                            <DataGridTextColumn Header="Mz, kN·м" Binding="{Binding Mz, StringFormat={}{0:0.#####}}" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </GroupBox>

                            <!-- Импорт из Excel -->
                            <GroupBox Header="Импорт из Excel результатов расчета РСУ и РСН" Style="{StaticResource SectionGroup}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Style="{StaticResource ToolbarButton}" Content="Добавить данные РСУ из Excel" Command="{Binding ImportRsuFromExcelCommand}" Click="ImportRsu_Click"/>
                                        <Button Grid.Column="2" Style="{StaticResource ToolbarButton}" Content="Добавить данные РСН из Excel" Command="{Binding ImportRsnFromExcelCommand}" Click="ImportRsn_Click"/>
                                        <Button Grid.Column="4" Style="{StaticResource ToolbarButton}" Content="Выполнить расчет" Command="{Binding ExecuteCalculationCommand}"/>
                                        <Button Grid.Column="6" Style="{StaticResource ToolbarButton}" Content="Очистить данные РСУ И РСН" Command="{Binding ClearDataCommand}"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1" Margin="0,0,0,8" VerticalAlignment="Center" Text="{Binding Status}"/>

                                    <GroupBox Grid.Row="2" Header="Расчетные данные из РСУ" Style="{StaticResource SectionGroup}">
                                        <DataGrid ItemsSource="{Binding RsuRows}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MaxHeight="75">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ZAGRUZKI" Binding="{Binding DclNo}" Width="*"/>
                                                <DataGridTextColumn Header="ELEM" Binding="{Binding Elem}" Width="*"/>
                                                <DataGridTextColumn Header="SECT" Binding="{Binding Sect}" Width="*"/>
                                                <DataGridTextColumn Header="N (кН)" Binding="{Binding N}" Width="*"/>
                                                <DataGridTextColumn Header="Mx (кН·м)" Binding="{Binding Mx}" Width="*"/>
                                                <DataGridTextColumn Header="My (кН·м)" Binding="{Binding My}" Width="*"/>
                                                <DataGridTextColumn Header="Qz (кН)" Binding="{Binding Qz}" Width="*"/>
                                                <DataGridTextColumn Header="Mz (кН·м)" Binding="{Binding Mz}" Width="*"/>
                                                <DataGridTextColumn Header="Qy (кН)" Binding="{Binding Qy}" Width="*"/>
                                                <DataGridTextColumn Header="Mw (кН·м²)" Binding="{Binding Mw}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </GroupBox>

                                    <GroupBox Grid.Row="3" Header="Расчетные данные из РСН" Style="{StaticResource SectionGroup}">
                                        <DataGrid ItemsSource="{Binding RsnRows}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MaxHeight="75">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="RSN No" Binding="{Binding DclNo}" Width="*"/>
                                                <DataGridTextColumn Header="KoE/Tip KE" Binding="{Binding ElemType}" Width="*"/>
                                                <DataGridTextColumn Header="ELEM" Binding="{Binding Elem}" Width="*"/>
                                                <DataGridTextColumn Header="SECT" Binding="{Binding Sect}" Width="*"/>
                                                <DataGridTextColumn Header="N (кН)" Binding="{Binding N}"       Width="*"/>
                                                <DataGridTextColumn Header="Mx (кН·м)" Binding="{Binding Mx}"     Width="*"/>
                                                <DataGridTextColumn Header="My (кН·м)" Binding="{Binding My}"     Width="*"/>
                                                <DataGridTextColumn Header="Qz (кН)" Binding="{Binding Qz}"     Width="*"/>
                                                <DataGridTextColumn Header="Mz (кН·м)" Binding="{Binding Mz}"     Width="*"/>
                                                <DataGridTextColumn Header="Qy (кН)" Binding="{Binding Qy}"     Width="*"/>
                                                <DataGridTextColumn Header="Mw (кН·м²)" Binding="{Binding Mw}"     Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </GroupBox>
                                </Grid>
                            </GroupBox>


                            <!-- Статус -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontWeight="SemiBold" Text="Статус:"/>
                                <TextBlock Margin="8,0,0,0" Text="{Binding Status}"/>
                            </StackPanel>

                        </StackPanel>
                    </Viewbox>
                </ScrollViewer>
            </DockPanel>

            <!-- Водяной знак SDE — поверх всего, не скроллится -->
        </Grid>
    </Border>
</Window>
